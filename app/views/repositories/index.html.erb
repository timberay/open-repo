<div class="max-w-7xl mx-auto">
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-blue-900 dark:text-white mb-2">Docker Registry</h1>
    <p class="text-blue-700 dark:text-gray-400">Browse and search Docker images from your registry</p>
  </div>

  <div class="mb-6 bg-blue-50 dark:bg-gray-800 rounded-lg shadow border border-blue-200 dark:border-gray-700 p-4">
    <%= form_with url: repositories_path, method: :get,
        data: { controller: "search", search_target: "form", turbo_frame: "repositories" },
        class: "flex flex-col sm:flex-row gap-4" do |f| %>

      <div class="flex-1">
        <%= f.text_field :q,
          value: params[:q],
          placeholder: "Search repositories...",
          data: { action: "input->search#search" },
          class: "block w-full py-2.5 px-4 rounded-lg border-blue-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 bg-white dark:bg-gray-700 text-blue-900 dark:text-white text-base" %>
      </div>

      <div class="sm:w-48">
        <%= f.select :sort,
          options_for_select([
            ["Recent", ""],
            ["Name (A-Z)", "name"],
            ["Size", "size"],
            ["Pulls", "pulls"]
          ], params[:sort]),
          {},
          {
            data: { action: "change->search#search" },
            class: "block w-full py-2.5 px-4 rounded-lg border-blue-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 bg-white dark:bg-gray-700 text-blue-900 dark:text-white text-base"
          } %>
      </div>
    <% end %>
  </div>

  <%= turbo_frame_tag "repositories" do %>
    <% if @repositories.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-6">
        <% @repositories.each do |repository| %>
          <%= render "repository_card", repository: repository %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
        </svg>
        <h3 class="mt-2 text-lg font-medium text-blue-900 dark:text-white">No repositories found</h3>
        <p class="mt-1 text-blue-600 dark:text-gray-400">
          <% if params[:q].present? %>
            Try adjusting your search query
          <% else %>
            Push an image to get started
          <% end %>
        </p>
      </div>
    <% end %>
  <% end %>
</div>
