<div class="max-w-7xl mx-auto">
  <div class="mb-6">
    <%= link_to repositories_path, class: "inline-flex items-center text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Repositories
    <% end %>
  </div>

  <div class="bg-blue-50 dark:bg-gray-800 rounded-lg shadow border border-blue-200 dark:border-gray-700 p-6 mb-8">
    <div class="flex items-center justify-between mb-4">
      <h1 class="text-3xl font-bold text-blue-900 dark:text-white"><%= @repository.name %></h1>
      <div class="flex items-center gap-2">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200">
          <%= @tags.count %> tags
        </span>
        <span class="text-sm text-blue-600 dark:text-gray-400"><%= human_size(@repository.total_size) %></span>
      </div>
    </div>

    <% if @repository.description.present? %>
      <p class="text-blue-700 dark:text-gray-400 mb-4"><%= @repository.description %></p>
    <% end %>

    <div class="mt-4 pt-4 border-t border-blue-200 dark:border-gray-700">
      <details class="group">
        <summary class="cursor-pointer text-sm text-blue-600 dark:text-gray-400 hover:text-blue-800 dark:hover:text-gray-300">
          Edit description & maintainer
        </summary>
        <div class="mt-3">
          <%= form_with model: @repository, url: repository_path(@repository.name), method: :patch, class: "space-y-3" do |f| %>
            <div>
              <%= f.text_area :description, rows: 2, placeholder: "Repository description...",
                class: "block w-full rounded-lg border-blue-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-blue-900 dark:text-white text-sm" %>
            </div>
            <div>
              <%= f.text_field :maintainer, placeholder: "Maintainer...",
                class: "block w-full rounded-lg border-blue-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-blue-900 dark:text-white text-sm" %>
            </div>
            <%= f.submit "Save", class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium" %>
          <% end %>
        </div>
      </details>
    </div>

    <% if @tags.any? %>
      <div class="mt-3 bg-blue-100 dark:bg-gray-900 rounded-lg px-4 py-2">
        <code class="text-sm text-blue-800 dark:text-blue-300"><%= docker_pull_command(@repository.name, @tags.first.name) %></code>
      </div>
    <% end %>
  </div>

  <% if @tags.any? %>
    <div class="bg-blue-50 dark:bg-gray-800 rounded-lg shadow border border-blue-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-blue-200 dark:divide-gray-700">
          <thead class="bg-blue-100 dark:bg-gray-900">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-blue-600 dark:text-gray-400 uppercase tracking-wider">Tag</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-blue-600 dark:text-gray-400 uppercase tracking-wider">Digest</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-blue-600 dark:text-gray-400 uppercase tracking-wider">Size</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-blue-600 dark:text-gray-400 uppercase tracking-wider">Arch</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-blue-600 dark:text-gray-400 uppercase tracking-wider">Pulls</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-blue-600 dark:text-gray-400 uppercase tracking-wider">Updated</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-blue-600 dark:text-gray-400 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-blue-50 dark:bg-gray-800 divide-y divide-blue-200 dark:divide-gray-700">
            <% @tags.each do |tag| %>
              <tr class="hover:bg-blue-100 dark:hover:bg-gray-700">
                <td class="px-6 py-4 whitespace-nowrap">
                  <%= link_to tag.name, repository_tag_path(@repository.name, tag),
                    class: "text-blue-600 dark:text-blue-400 hover:underline font-medium" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-blue-700 dark:text-gray-400 font-mono">
                  <%= short_digest(tag.manifest.digest) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-blue-700 dark:text-gray-400">
                  <%= human_size(tag.manifest.size) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-blue-700 dark:text-gray-400">
                  <%= tag.manifest.architecture %>/<%= tag.manifest.os %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-blue-700 dark:text-gray-400">
                  <%= tag.manifest.pull_count %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-blue-700 dark:text-gray-400">
                  <%= time_ago_in_words(tag.updated_at) %> ago
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                  <%= button_to "Delete", repository_tag_path(@repository.name, tag), method: :delete,
                    data: { turbo_confirm: "Delete tag '#{tag.name}'?" },
                    class: "text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="text-center py-12">
      <h3 class="mt-2 text-lg font-medium text-blue-900 dark:text-white">No tags found</h3>
      <p class="mt-1 text-blue-600 dark:text-gray-400">Push an image to create tags</p>
    </div>
  <% end %>

  <div class="mt-6 flex items-center justify-end">
    <%= button_to "Delete Repository", repository_path(@repository.name), method: :delete,
      data: { turbo_confirm: "Delete repository '#{@repository.name}' and all its tags?" },
      class: "px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 text-sm font-medium" %>
  </div>
</div>
