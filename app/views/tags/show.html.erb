<div class="max-w-7xl mx-auto">
  <div class="mb-6">
    <%= link_to repository_path(@repository.name), class: "inline-flex items-center text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to <%= @repository.name %>
    <% end %>
  </div>

  <div class="bg-blue-50 dark:bg-gray-800 rounded-lg shadow border border-blue-200 dark:border-gray-700 p-6 mb-8">
    <h1 class="text-3xl font-bold text-blue-900 dark:text-white mb-2"><%= @repository.name %>:<%= @tag.name %></h1>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-4">
      <div>
        <dt class="text-xs text-blue-600 dark:text-gray-400 uppercase">Digest</dt>
        <dd class="text-sm font-mono text-blue-900 dark:text-white"><%= short_digest(@manifest.digest) %></dd>
      </div>
      <div>
        <dt class="text-xs text-blue-600 dark:text-gray-400 uppercase">Size</dt>
        <dd class="text-sm text-blue-900 dark:text-white"><%= human_size(@manifest.size) %></dd>
      </div>
      <div>
        <dt class="text-xs text-blue-600 dark:text-gray-400 uppercase">Architecture</dt>
        <dd class="text-sm text-blue-900 dark:text-white"><%= @manifest.architecture %>/<%= @manifest.os %></dd>
      </div>
      <div>
        <dt class="text-xs text-blue-600 dark:text-gray-400 uppercase">Pull Count</dt>
        <dd class="text-sm text-blue-900 dark:text-white"><%= @manifest.pull_count %></dd>
      </div>
    </div>

    <div class="mt-4 bg-blue-100 dark:bg-gray-900 rounded-lg px-4 py-2">
      <code class="text-sm text-blue-800 dark:text-blue-300"><%= docker_pull_command(@repository.name, @tag.name) %></code>
    </div>
  </div>

  <div class="bg-blue-50 dark:bg-gray-800 rounded-lg shadow border border-blue-200 dark:border-gray-700 overflow-hidden mb-8">
    <div class="px-6 py-4 border-b border-blue-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-blue-900 dark:text-white">Layers (<%= @layers.count %>)</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-blue-200 dark:divide-gray-700">
        <thead class="bg-blue-100 dark:bg-gray-900">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-blue-600 dark:text-gray-400 uppercase">#</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-blue-600 dark:text-gray-400 uppercase">Digest</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-blue-600 dark:text-gray-400 uppercase">Size</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-blue-200 dark:divide-gray-700">
          <% @layers.each do |layer| %>
            <tr>
              <td class="px-6 py-3 text-sm text-blue-700 dark:text-gray-400"><%= layer.position %></td>
              <td class="px-6 py-3 text-sm font-mono text-blue-700 dark:text-gray-400"><%= short_digest(layer.blob.digest) %></td>
              <td class="px-6 py-3 text-sm text-blue-700 dark:text-gray-400"><%= human_size(layer.blob.size) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <% if @manifest.docker_config.present? %>
    <div class="bg-blue-50 dark:bg-gray-800 rounded-lg shadow border border-blue-200 dark:border-gray-700 p-6">
      <h2 class="text-lg font-semibold text-blue-900 dark:text-white mb-4">Docker Config</h2>
      <pre class="bg-blue-100 dark:bg-gray-900 rounded-lg p-4 text-sm text-blue-800 dark:text-blue-300 overflow-x-auto"><%= JSON.pretty_generate(JSON.parse(@manifest.docker_config)) rescue @manifest.docker_config %></pre>
    </div>
  <% end %>
</div>
